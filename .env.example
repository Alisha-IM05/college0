# Copy to .env and adjust. See https://mailpit.axllent.org/docs/

# --- Mailpit (local SMTP catcher) ---
# Run: mailpit   then open http://127.0.0.1:8025 for the inbox UI
MAIL_SERVER=127.0.0.1
MAIL_PORT=1025
MAIL_FROM=college0@localhost
MAIL_USE_TLS=0
PUBLIC_BASE_URL=http://127.0.0.1:5001

# If your SMTP requires auth (not default Mailpit):
# MAIL_USERNAME=
# MAIL_PASSWORD=
